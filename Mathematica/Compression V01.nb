                RowBox[{
                 RowBox[{"-", " ", "b"}], "-", "x"}], ")"}], " ", "/", "a"}], 
              " ", ",", 
              RowBox[{
               RowBox[{"(", " ", 
                RowBox[{
                 RowBox[{"-", " ", "b"}], "+", "x"}], ")"}], " ", "/", 
               "a"}]}], " ", "}"}]}]}], "]"}]}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{

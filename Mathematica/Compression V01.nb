Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Baseline", " ", "P"}], "-", "noise"}], " ", "=", 
    " \[InvisibleSpace]", 
    RowBox[{
    "0.5", " ", "reflects", " ", "random", " ", "alignment", " ", "of", " ", 
     "independent", " ", "conditional", " ", "events"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "xi", ",", "xj", ",", "yi", ",", "yj", ",", "T", ",", "t", ",", "c"}], 
     "]"}], ";", 
    RowBox[{"T", "=", 
     RowBox[{"10", "^", "6"}]}], ";", 
    RowBox[{"c", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"t", "=", "1"}], ",", 
      RowBox[{"t", "<=", "T"}], ",", 
      RowBox[{"t", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"xi", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"xj", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yi", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yj", "=", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", "1"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"c", "+=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"And", "[", 
            RowBox[{
             RowBox[{"xi", ">", "xj"}], ",", 
             RowBox[{"yi", ">", "yj"}]}], "]"}], "||", 
           RowBox[{"And", "[", 
            RowBox[{
             RowBox[{"xi", "<", "xj"}], ",", 
             RowBox[{"yi", "<", "yj"}]}], "]"}]}], ",", "1", ",", "0"}], 
         "]"}]}]}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<P-noise = \>\"", ",", 
      RowBox[{
       RowBox[{"N", "[", "c", "]"}], "/", 
       RowBox[{"N", "[", "T", "]"}]}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Example", " ", 
     RowBox[{"output", ":", 
      RowBox[{
       RowBox[{"P", "-", "noise"}], "\[TildeTilde]", "0.5004"}]}]}], 

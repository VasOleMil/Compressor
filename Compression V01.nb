Cell[CellGroupData[{

Cell["1. Aproaching elements, \t(RV < 0) ", "Subsection",ExpressionUUID->"eb1e1060-902d-4f02-9a67-3243072e3dc3"],

Cell[TextData[{
 "1.1  Interaction exists, time left dT (1, 3):\n\t",
 Cell[BoxData[
  RowBox[{"dT", "\[Equal]", " ", 
   FractionBox[
    RowBox[{
     RowBox[{"-", "RV"}], "-", 
     SqrtBox[
      RowBox[{
       RowBox[{"VV", " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"Ri", "+", "Rj"}], ")"}], 
             RowBox[{"(", 
              RowBox[{"1", "+", 
               RowBox[{"G", " ", "dT"}]}], ")"}]}], ")"}], "2"], "-", "RR"}], 
         ")"}]}], "+", 
       SuperscriptBox["RV", "2"]}]]}], "VV"]}]],ExpressionUUID->
  "60c2b759-8b68-4e32-a81e-96e66f9b0216"],
 "\t\t\t\t\t\t\t(1.1.1)\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[Equal]", " ", 
    RowBox[{
     RowBox[{"VV", " ", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Ri", "+", "Rj"}], ")"}], 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"G", " ", "dT"}]}], ")"}]}], ")"}], "2"], "-", "RR"}], 
       ")"}]}], "+", 
     SuperscriptBox["RV", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "a20838b7-e1d6-4ccc-911b-df88aac477c2"],
 "\t\t\t\t\t\t\t(1.1.2)\n\n\t",
 Cell[BoxData[
  TagBox[
   RowBox[{"dT", " ", "\[Equal]", " ", 
    FractionBox[
     RowBox[{
      RowBox[{
       RowBox[{"-", "G"}], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "+", "RV", "+", 
      SqrtBox[
       RowBox[{
        RowBox[{
         SuperscriptBox["G", "2"], " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], " ", "RR"}], "-", 
        RowBox[{"2", " ", "G", " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], " ", "RV"}], "+", 
        SuperscriptBox["RV", "2"], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], "-", "RR"}], ")"}], " ", 
         "VV"}]}]]}], 
     RowBox[{
      RowBox[{
       SuperscriptBox["G", "2"], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "-", "VV"}]]}],
   Function[BoxForm`e$, 
    TableForm[BoxForm`e$]]]],ExpressionUUID->
  "72e06b9c-8188-4048-a784-cf1c6a24f17c"],
 "\t\t\t(1.1.3)\n\n\n\t",
 Cell[BoxData[
  TagBox[
   RowBox[{"D", " ", "\[Equal]", " ", 
    RowBox[{
     RowBox[{
      SuperscriptBox["G", "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], " ", "RR"}], "-", 
     RowBox[{"2", " ", "G", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], " ", "RV"}], "+", 
     SuperscriptBox["RV", "2"], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], "-", "RR"}], ")"}], " ", 
      "VV"}]}]}],
   Function[BoxForm`e$, 
    TableForm[BoxForm`e$]]]],ExpressionUUID->
  "9b531290-fb8b-483a-afdf-665573b3f859"],
 "\t\t(1.1.4)\n\t\n\tsecond root were gave up due to different form of result \
at G \[Rule] 0.\n\n1.2 Out of range, growing (G > 0) smaller than minimal \
distance: \n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"r", "*", 
     RowBox[{"sin", "(", "\[Alpha]", ")"}]}], "=", 
    RowBox[{
     RowBox[{"r", " ", 
      SqrtBox[
       RowBox[{"1", "-", 
        SuperscriptBox[
         RowBox[{"cos", "(", "\[Alpha]", ")"}], "2"]}]]}], "=", 
     RowBox[{
      RowBox[{"r", 
       SqrtBox[
        RowBox[{"1", "-", 
         SuperscriptBox[
          RowBox[{"(", 
           FractionBox[
            RowBox[{"(", 
             RowBox[{"r", " ", "*", "V"}], ")"}], 
            RowBox[{"r", "*", "V"}]], ")"}], "2"]}]]}], "=", " ", 
      RowBox[{
       SqrtBox[
        FractionBox[
         RowBox[{"  ", 
          RowBox[{
           RowBox[{"RR", " ", "VV"}], "-", 
           SuperscriptBox["RV", "2"]}]}], 
         RowBox[{" ", "VV"}]]], "=", "const"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"1d869289-5881-4d47-999a-1fdf33184bf6"],
 "\t\t\t(1.2.1)\n\t\n\t",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Ri", "+", "Rj"}], ")"}], 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"G", " ", "dT"}]}], ")"}]}], ")"}], "2"], " ", 
      "\[LessEqual]", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"r", "*", 
         RowBox[{"sin", "(", "\[Alpha]", ")"}]}], ")"}], "2"]}], " ", "=", 
     " ", 
     RowBox[{"RR", "-", 
      FractionBox[
       RowBox[{" ", 
        SuperscriptBox["RV", "2"], " "}], "VV"]}]}], "\[IndentingNewLine]"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"d", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"VV", " ", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"Ri", "+", "Rj"}], ")"}], 
            RowBox[{"(", 
             RowBox[{"1", "+", 
              RowBox[{"G", " ", "dT"}]}], ")"}]}], ")"}], "2"], "-", "RR"}], 
        ")"}]}], "+", 
      SuperscriptBox["RV", "2"]}], "\[LessEqual]", " ", "0", " "}]}], 
   TraditionalForm]}],ExpressionUUID->"30ba3bfc-accb-43d8-9fcd-71fb7764a441"],
 "\n\n\t- Solving implicit equation (1.1.1) equal to correct aiming, D == 0 \
geometrical touching. \n\t- Existance of dT, (D > 0) provides existance of \
elements interaction.\n\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"dT", "\[Equal]", " ", "null"}], ";", " ", 
     RowBox[{"(", 
      RowBox[{"RV", "<", "0"}], ")"}]}], ",", 
    RowBox[{"(", 
     RowBox[{"D", "\[LessEqual]", " ", "0"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"ab5ab237-3e6b-4693-8f43-4167fa99db37"],
 "\t\t\t\t\t\t\t\t\t(1.2.2)\n\t\t\n1.3 Low speed, shrinking (G < 0) faster \
than approaching\n\tNon central approaching movement is in case of previous \
section. Otherwise, RV has opposite aligned r and V.\n\tDenominator goes \
through zero, providing infinite time for equal shrinking and approaching \
speeds. \n\t \t \n\tSide approaching always slower than straight central one, \
at least in Newton mechanics, \n\t shrinking element goes nearby without \
interaction, so region of physically  void solutions can be extended \n\t due \
to exclusion of central alignment condition (RV RV\[Equal]RR VV).\n\t \n\t ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"dT", " ", "\[Equal]", "null"}], ";", 
    RowBox[{"(", 
     RowBox[{"RV", "<", "0"}], ")"}]}], ",", 
   RowBox[{"(", 
    RowBox[{"G", "<", "0"}], ")"}], ",", 
   RowBox[{"(", 
    RowBox[{"VV", "\[LessEqual]", 
     RowBox[{
      SuperscriptBox["G", "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}]}], ")"}]}]],ExpressionUUID->
  "88b93217-d778-4d27-a14f-9c0e5d14beaf"],
 "\t\t\t\t(1.3.1)\n\t\t\t\n1.4 Peculiarity ",
 Cell[BoxData[
  RowBox[{"VV", "\[Equal]", 
   RowBox[{
    SuperscriptBox["G", "2"], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}]}]],ExpressionUUID->
  "abe0b484-3859-46d1-83a2-c1eb374de60b"],
 ", solving implicit form at this condition give one solution, \n\tas well as \
case a==0 for the square equation. \n\tAccording to 1.3, physics may be \
provided for the case of growing,\n\t\n\t",
 Cell[BoxData[
  RowBox[{"dT", "\[Equal]", 
   FractionBox[
    RowBox[{"RR", " ", "-", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], 
    RowBox[{"2", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"G", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "-", " ", "RV"}], 
      ")"}]}]]}]],ExpressionUUID->"544edc36-15da-4086-8464-560b6c552dd8"],
 "; (G > 0)\t\t\t\t\t\t\t\t(1.4.1)\n\t\n\twhich has own peculiarity ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"G", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "\[Equal]", " ", "RV"}]],
  ExpressionUUID->"ba37e82a-02b7-449b-9e6e-c5b5b55f0a2b"],
 ", combining with initial one, obtain \n\t\n\t",
 Cell[BoxData[
  RowBox[{"VV", "\[Equal]", 
   RowBox[{"G", " ", "RV"}]}]],ExpressionUUID->
  "67a6e2c1-1ca0-40b8-8e50-9e895edca098"],
 " which with approaching demands shrinking, that contradicts to and is out \
of section conditions,  \n\t\n\t ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"dT", " ", "\[Equal]", "null"}], ";", 
    RowBox[{"(", 
     RowBox[{"RV", "<", "0"}], ")"}]}], ",", 
   RowBox[{"(", 
    RowBox[{"G", "<", "0"}], ")"}], ",", " ", 
   RowBox[{"VV", "\[Equal]", 
    RowBox[{
     SuperscriptBox["G", "2"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}]}], ",", 
   RowBox[{"(", 
    RowBox[{"VV", "\[Equal]", 
     RowBox[{"G", " ", "RV"}]}], ")"}]}]],ExpressionUUID->
  "f11e8f61-53df-4bca-a8fb-67be4ef64421"],
 "\t\n\t \n\tPhysically this condition is explicit at central interaction, \
aproaching and growing speed are equal,\n\tbut the speed aplied to center of \
elements with fixed interaction point. \n\t\n\tIntrinsic peculiarity is in \
the case of  (1.3.1) region. \t\n\t\n"
}], "Text",ExpressionUUID->"a452878a-9821-4f1b-b95d-7a3457f4d4c8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Distancing elements, \t(RV \[GreaterEqual] 0) ", "Subsection",ExpressionUUID->"e64d56dd-3199-4cef-891d-3bd9b68d53c8"],

Cell[TextData[{
 "2.1  Interaction exists due to growing only (G > 0).  time left dT (1, 3):\n\
\t",
 Cell[BoxData[
  RowBox[{"dT", "\[Equal]", " ", 
   FractionBox[
    RowBox[{
     SqrtBox[
      RowBox[{
       RowBox[{"VV", " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"Ri", "+", "Rj"}], ")"}], 
             RowBox[{"(", 
              RowBox[{"1", "+", 
               RowBox[{"G", " ", "dT"}]}], ")"}]}], ")"}], "2"], "-", "RR"}], 
         ")"}]}], "+", 
       SuperscriptBox["RV", "2"]}]], "-", "RV"}], "VV"]}]],ExpressionUUID->
  "b88fd239-5d4b-4ede-bd5e-2e6e792c1063"],
 "\t\t\t\t\t\t\t(2.1.1)\n\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[Equal]", " ", 
    RowBox[{
     RowBox[{"VV", " ", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Ri", "+", "Rj"}], ")"}], 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"G", " ", "dT"}]}], ")"}]}], ")"}], "2"], "-", "RR"}], 
       ")"}]}], "+", 
     SuperscriptBox["RV", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "67e9e4db-6739-4a59-9f40-3c98d98057d6"],
 "\t\t\t\t\t\t\t(2.1.2)\n\n\t",
 Cell[BoxData[
  TagBox[
   RowBox[{"dT", " ", "\[Equal]", " ", 
    FractionBox[
     RowBox[{
      RowBox[{
       RowBox[{"-", "G"}], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "+", "RV", "+", 
      SqrtBox[
       RowBox[{
        RowBox[{
         SuperscriptBox["G", "2"], " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], " ", "RR"}], "-", 
        RowBox[{"2", " ", "G", " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], " ", "RV"}], "+", 
        SuperscriptBox["RV", "2"], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], "-", "RR"}], ")"}], " ", 
         "VV"}]}]]}], 
     RowBox[{
      RowBox[{
       SuperscriptBox["G", "2"], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "-", "VV"}]]}],
   Function[BoxForm`e$, 
    TableForm[BoxForm`e$]]]],ExpressionUUID->
  "0bbf4c9a-4a9d-4c81-bbde-0b481fd6c1c0"],
 "\t\t\t(2.1.3)\n\n\n\t",
 Cell[BoxData[
  TagBox[
   RowBox[{"D", " ", "\[Equal]", " ", 
    RowBox[{
     RowBox[{
      SuperscriptBox["G", "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], " ", "RR"}], "-", 
     RowBox[{"2", " ", "G", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], " ", "RV"}], "+", 
     SuperscriptBox["RV", "2"], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], "-", "RR"}], ")"}], " ", 
      "VV"}]}]}],
   Function[BoxForm`e$, 
    TableForm[BoxForm`e$]]]],ExpressionUUID->
  "49ffff31-ef6a-4382-9dad-d313945e9257"],
 "\t\t(2.1.4)\n\t \n\t second root were gave up using continuaty by \
RV\[Rule]0 and dicontinuaty for G\[Rule]0\n\t solution obtained is identical \
to aproaching, RV < 0\n\n2.2 Out of range, growing (G > 0) smaller than \
minimal distance: \n\tidentical to aproaching, RV < 0:\n\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"dT", "\[Equal]", " ", "null"}], ";", " ", 
     RowBox[{"(", 
      RowBox[{"RV", " ", "\[GreaterEqual]", " ", "0"}], ")"}]}], ",", 
    RowBox[{"(", 
     RowBox[{"D", "\[LessEqual]", " ", "0"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"0805a679-b22b-480b-bc60-cd0d2907fdf9"],
 "\t\t\t\t\t\t\t\t(2.2.2)\n\t\t\t\n2.3 Peculiarity ",
 Cell[BoxData[
  RowBox[{"VV", "\[Equal]", 
   RowBox[{
    SuperscriptBox["G", "2"], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}]}]],ExpressionUUID->
  "d97fcc88-c5c4-4837-9c20-24ac6df9eb4a"],
 ", solving implicit form at this condition give one solution. \n\tValue is \
the same as for (RV < 0)\n\t\n\t",
 Cell[BoxData[
  RowBox[{"dT", "\[Equal]", 
   FractionBox[
    RowBox[{"RR", " ", "-", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], 
    RowBox[{"2", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"G", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "-", " ", "RV"}], 
      ")"}]}]]}]],ExpressionUUID->"b50d2965-86f0-472d-80b6-185416668c69"],
 "; (G > 0)\t\t\t\t\t\t\t\t(2.3.1)\n\t\n\taloso has own peculiarity ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"G", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "\[Equal]", "  ", "RV"}]],
  ExpressionUUID->"50386cc8-2dd3-487e-a2e5-5442acdac14e"],
 ", combining with initial one, obtain \n\t\n\t",
 Cell[BoxData[
  RowBox[{"VV", "\[Equal]", " ", 
   RowBox[{"G", " ", "RV"}]}]],ExpressionUUID->
  "c78eec2a-3f65-4bce-921d-9463f00d2b52"],
 ": or distancing equal growing:\n\t\n\t ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"dT", " ", "\[Equal]", "null"}], ";", 
    RowBox[{"(", 
     RowBox[{"RV", "\[GreaterEqual]", "0"}], ")"}]}], ",", 
   RowBox[{"(", 
    RowBox[{"G", ">", "0"}], ")"}], ",", " ", 
   RowBox[{"VV", "\[Equal]", 
    RowBox[{
     SuperscriptBox["G", "2"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}]}], ",", 
   RowBox[{"(", 
    RowBox[{"VV", "\[Equal]", 
     RowBox[{
      RowBox[{"-", " ", "G"}], " ", "RV"}]}], ")"}]}]],ExpressionUUID->
  "1ac02e1c-4b12-41af-a65a-b8d1804a84a4"],
 "\t\t(2.3.1)\n\t\n\t ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"dT", " ", "\[Equal]", "null"}], ";", 
    RowBox[{"(", 
     RowBox[{"RV", "<", "0"}], ")"}]}], ",", 
   RowBox[{"(", 
    RowBox[{"G", "<", "0"}], ")"}], ",", " ", 
   RowBox[{"VV", "\[Equal]", 
    RowBox[{
     SuperscriptBox["G", "2"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}]}], ",", 
   RowBox[{"(", 
    RowBox[{"VV", "\[Equal]", 
     RowBox[{
      RowBox[{"+", " ", "G"}], " ", "RV"}]}], ")"}]}]],ExpressionUUID->
  "3c8080d0-c75b-4e6d-a735-b3dfd9c64bf9"],
 "\t\t(1.3.1)* \t\n\t\n"
}], "Text",ExpressionUUID->"774b0c39-a98d-4af4-86bc-a49298b0ebcb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Element element interaction:", "Subsection",ExpressionUUID->"7a9caac0-3d81-4f65-8664-f84cea493e82"],

Cell[TextData[{
 "3.1  Interaction exists  time left dT \n\t\n\t",
 Cell[BoxData[
  TagBox[
   RowBox[{"dT", " ", "\[Equal]", " ", 
    FractionBox[
     RowBox[{
      RowBox[{
       RowBox[{"-", "G"}], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "+", "RV", "-", 
      SqrtBox[
       RowBox[{
        RowBox[{
         SuperscriptBox["G", "2"], " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], " ", "RR"}], "-", 
        RowBox[{"2", " ", "G", " ", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], " ", "RV"}], "+", 
        SuperscriptBox["RV", "2"], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], "-", "RR"}], ")"}], " ", 
         "VV"}]}]]}], 
     RowBox[{
      RowBox[{
       SuperscriptBox["G", "2"], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "-", "VV"}]]}],
   Function[BoxForm`e$, 
    TableForm[BoxForm`e$]]]],ExpressionUUID->
  "10751c05-bbc2-482b-95a4-3dfed1cd5326"],
 "\t\t\t(1)\n\t\n\n\t",
 Cell[BoxData[
  TagBox[
   RowBox[{
    RowBox[{"D", " ", "\[Equal]", " ", 
     RowBox[{
      RowBox[{
       SuperscriptBox["G", "2"], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], " ", "RR"}], "-", 
      RowBox[{"2", " ", "G", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}]}]}], " ", "|", "RV", "|", 
    RowBox[{
     RowBox[{"+", 
      SuperscriptBox["RV", "2"]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"Ri", "+", "Rj"}], ")"}], "2"], "-", "RR"}], ")"}], " ", 
      "VV"}]}]}],
   Function[BoxForm`e$, 
    TableForm[BoxForm`e$]]]],ExpressionUUID->
  "0637ae80-c9c5-48fc-a5ee-65e095520663"],
 "\t\t(2)\n\t\n\texplicit form includes case of equal elements speed VV \
\[Equal] 0\n\n3.2 Out of range: \n\t\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dT", "\[Equal]", " ", "null"}], ";", " ", 
    RowBox[{"(", 
     RowBox[{"D", "\[LessEqual]", " ", "0"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"054f57fe-53b0-4522-b857-29a2e5e4588b"],
 "\t\t\t\t\t\t\t\t\t\t(1)\n\t\t\t\n3.3 Peculiarity ",
 Cell[BoxData[
  RowBox[{"VV", "\[Equal]", 
   RowBox[{
    SuperscriptBox["G", "2"], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}]}]],ExpressionUUID->
  "57699d6f-2391-410d-abe6-d075b8970f68"],
 ",\n\t\n\t",
 Cell[BoxData[
  RowBox[{"dT", "\[Equal]", 
   FractionBox[
    RowBox[{"RR", " ", "-", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], 
    RowBox[{"2", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"G", " ", 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "+", " ", "RV"}], 
      ")"}]}]]}]],ExpressionUUID->"57472211-b9f8-44aa-971d-0fff31bb929b"],
 "; \t\t\t\t\t\t\t\t\t(1)\n\t\n\tpeculiarity ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"G", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], "\[Equal]", " ", "RV"}]],
  ExpressionUUID->"d10476b0-78b1-40ed-a954-c1709fe06465"],
 ",  or ",
 Cell[BoxData[
  RowBox[{"VV", "\[Equal]", " ", 
   RowBox[{"G", " ", "RV"}]}]],ExpressionUUID->
  "a4b9b7bc-7945-460f-8f86-65fb2d0dc21b"],
 ": \n\t\n\t ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"dT", " ", "\[Equal]", "null"}], ";"}]],ExpressionUUID->
  "cf59de3d-b58d-4203-a071-0bd1f779a8c6"],
 "\t\t\t\t\t\t\t\t\t\t\t(2)\n\t \n3.4 Suggested calculation form:\n\t ",
 Cell[BoxData[{
  RowBox[{
   RowBox[{"LL", "=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"Ri", "+", "Rj"}], ")"}], "2"]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Rv", "=", 
    RowBox[{"G", " ", "LL"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Vv", "=", 
    RowBox[{"G", " ", "Rv"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"LL", " ", "-=", " ", "RR"}], ";"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"TT", "=", 
     RowBox[{
      RowBox[{"LL", " ", "VV"}], " ", "+", 
      SuperscriptBox["RV", "2"], "+", 
      RowBox[{"Vv", " ", "RR"}], " ", "-", 
      RowBox[{"2", " ", "Rv", " ", "RV"}]}]}], ";"}], 
   "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Vv", "-=", "VV"}], ";"}], " "}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Rv", "+=", "RV"}], ";"}], 
   "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"dT", "=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"TT", "\[LessEqual]", " ", "0"}], ",", 
      RowBox[{"-", "1"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"VV", "\[Equal]", " ", "0"}], ",", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"Rv", "\[Equal]", "0"}], ",", 
          RowBox[{"-", "1"}], ",", 
          FractionBox["LL", 
           RowBox[{"2", "Rv"}]]}], "]"}], ",", 
        FractionBox[
         RowBox[{
          SqrtBox["TT"], "-", " ", "Rv"}], "Vv"]}], "]"}]}], "]"}]}], ";"}]}],
  ExpressionUUID->"f05aa201-98c0-4499-a924-abf459637f51"],
 "\t\t(1)\n\n3.5  Sizing speed,\n\tcurrent radii in dT calculation \n\t",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"R", 
     RowBox[{"(", "t", ")"}]}], "=", 
    RowBox[{
     SubscriptBox["R", "s"], 
     RowBox[{"(", 
      RowBox[{"1", "+", 
